---
import Base from '../layouts/Base.astro';
import { clinic, whatsappLink } from '../config/clinic';

const waUrl = whatsappLink();
const title = `Contato e Agendamento — ${clinic.name} | ${clinic.city}`;
const description = `Entre em contato com a ${clinic.name}. Agende sua consulta pelo WhatsApp, formulário online ou telefone. Atendimento humanizado em ${clinic.city}.`;

const schema = {
  '@context': 'https://schema.org',
  '@type': 'MedicalClinic',
  name: clinic.name,
  telephone: clinic.phone,
  email: clinic.email,
  address: {
    '@type': 'PostalAddress',
    streetAddress: clinic.address.street,
    addressLocality: clinic.city,
    addressCountry: 'BR',
  },
  openingHoursSpecification: [
    { '@type': 'OpeningHoursSpecification', dayOfWeek: ['Monday','Tuesday','Wednesday','Thursday','Friday'], opens: '08:00', closes: '18:00' },
    { '@type': 'OpeningHoursSpecification', dayOfWeek: ['Saturday'], opens: '08:00', closes: '12:00' },
  ],
};
---

<Base title={title} description={description}>
  <script type='application/ld+json' set:html={JSON.stringify(schema)} />

  <section class='contato-hero'>
    <div class='container contato-hero__inner'>
      <span class='contato-hero__eyebrow'>Fale com a gente</span>
      <h1 class='contato-hero__title'>Agende sua consulta com facilidade</h1>
      <p class='contato-hero__lead'>
        Estamos aqui para atender você da forma mais conveniente. Escolha o canal de sua preferência e nossa equipe responde em até 15 minutos durante o horário comercial.
      </p>
    </div>
  </section>

  <section class='section'>
    <div class='container contato-grid'>
      <!-- CANAIS -->
      <div class='contato-left'>
        <h2 class='contato-col-title'>Canais de atendimento</h2>

        <article class='canal canal--highlight'>
          <div class='canal__icon'>
            <svg xmlns='http://www.w3.org/2000/svg' width='28' height='28' viewBox='0 0 24 24' fill='#25D366' aria-hidden='true'><path d='M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z'/></svg>
          </div>
          <div class='canal__info'>
            <h3>WhatsApp <span class='canal__badge'>Recomendado</span></h3>
            <p>A forma mais rápida de agendar. Fale com nossa equipe em tempo real.</p>
            <p class='canal__hours'>Resposta em até 15 min | Seg–Sex: 8h–18h | Sáb: 8h–12h</p>
            <a href={waUrl} class='btn btn-whatsapp' target='_blank' rel='noopener noreferrer' style='margin-top:var(--space-3)'>
              <svg xmlns='http://www.w3.org/2000/svg' width='16' height='16' viewBox='0 0 24 24' fill='currentColor' aria-hidden='true'><path d='M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z'/></svg>
              Falar pelo WhatsApp
            </a>
          </div>
        </article>

        <article class='canal'>
          <div class='canal__icon' aria-hidden='true'>
            <svg xmlns='http://www.w3.org/2000/svg' width='28' height='28' viewBox='0 0 24 24' fill='none' stroke='var(--color-primary)' stroke-width='1.5' stroke-linecap='round' stroke-linejoin='round'><path d='M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 13a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.6 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z'/></svg>
          </div>
          <div class='canal__info'>
            <h3>Telefone</h3>
            <p><a href={`tel:${clinic.phone.replace(/[^0-9]/g, '')}`}>{clinic.phone}</a></p>
            <p class='canal__hours'>Seg–Sex: 8h–18h | Sáb: 8h–12h</p>
          </div>
        </article>

        <div class='localizacao'>
          <h3 class='localizacao__title'>Onde estamos</h3>
          <p class='localizacao__address'>{clinic.address.street}<br />{clinic.address.cityState}</p>
          <p class='localizacao__ref'>{clinic.address.reference}</p>
          <div class='localizacao__hours'>
            <p>{clinic.hours.weekdays}</p>
            <p>{clinic.hours.saturday}</p>
            <p>{clinic.hours.sunday}</p>
          </div>
          <a href={clinic.address.mapsUrl} class='btn btn-secondary btn-sm' target='_blank' rel='noopener noreferrer' style='margin-top:var(--space-4)'>Abrir no Google Maps</a>
        </div>
      </div>

      <!-- FORMULÁRIO -->
      <div class='contato-right'>
        <h2 class='contato-col-title'>Envie uma mensagem</h2>
        <p class='form-intro'>Prefere deixar sua mensagem? Preencha o formulário e entraremos em contato.</p>
        <form id='contact-form' class='contact-form' novalidate>
          <div class='form-group'>
            <label for='nome' class='form-label form-label--required'>Nome completo</label>
            <input type='text' id='nome' name='nome' class='form-input' placeholder='Seu nome completo' required aria-required='true' autocomplete='name' />
          </div>
          <div class='form-group'>
            <label for='telefone' class='form-label form-label--required'>Telefone / WhatsApp</label>
            <input type='tel' id='telefone' name='telefone' class='form-input' placeholder='(00) 00000-0000' required aria-required='true' autocomplete='tel' />
          </div>
          <div class='form-group'>
            <label for='email' class='form-label'>E-mail</label>
            <input type='email' id='email' name='email' class='form-input' placeholder='seu@email.com' autocomplete='email' />
          </div>
          <div class='form-group'>
            <label for='especialidade' class='form-label'>Especialidade desejada</label>
            <select id='especialidade' name='especialidade' class='form-select'>
              <option value=''>Selecione uma especialidade</option>
              <option>Clínica Geral</option>
              <option>Cardiologia</option>
              <option>Dermatologia</option>
              <option>Ginecologia</option>
              <option>Ortopedia</option>
              <option>Outra</option>
            </select>
          </div>
          <div class='form-group'>
            <label for='mensagem' class='form-label form-label--required'>Mensagem</label>
            <textarea id='mensagem' name='mensagem' class='form-textarea' placeholder='Descreva brevemente o motivo do contato...' required aria-required='true'></textarea>
          </div>
          <div class='form-group'>
            <label class='form-checkbox'>
              <input type='checkbox' id='lgpd' name='lgpd' required aria-required='true' />
              <span>Aceito o tratamento dos meus dados conforme a <a href='/politica-de-privacidade' target='_blank'>Política de Privacidade</a>.</span>
            </label>
            <span class='form-error-msg' id='lgpd-error' role='alert' aria-live='polite' style='display:none'>Por favor, aceite a Política de Privacidade para continuar.</span>
          </div>
          <button type='submit' class='btn btn-primary btn-lg form-submit' id='submit-btn' style='width:100%;justify-content:center'>
            Enviar mensagem
          </button>
          <p class='form-lgpd-note'>Seus dados são tratados com segurança e confidencialidade, conforme a Lei Geral de Proteção de Dados (LGPD — Lei 13.709/2018).</p>
        </form>
      </div>
    </div>
  </section>
</Base>

<style>
  .contato-hero {
    background: linear-gradient(135deg, #2D6A4F 0%, #52B788 100%);
    padding: var(--space-20) 0;
    color: var(--color-text-inverse);
  }
  .contato-hero__inner { max-width: 640px; }
  .contato-hero__eyebrow {
    display: inline-block; font-size: var(--text-xs); font-weight: var(--font-semibold);
    letter-spacing: var(--tracking-wide); text-transform: uppercase;
    color: var(--color-accent-light); margin-bottom: var(--space-4);
  }
  .contato-hero__title { font-size: clamp(var(--text-4xl), 6vw, var(--text-5xl)); color: var(--color-text-inverse); margin-bottom: var(--space-4); }
  .contato-hero__lead { font-size: var(--text-lg); color: rgba(255,255,255,0.9); line-height: var(--leading-relaxed); max-width: 520px; }
  .contato-grid { display: grid; grid-template-columns: 1fr 1fr; gap: var(--space-12); align-items: start; }
  .contato-col-title { font-size: var(--text-2xl); margin-bottom: var(--space-6); }
  .canal {
    display: flex; gap: var(--space-4); align-items: flex-start;
    padding: var(--space-5);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    margin-bottom: var(--space-4);
    background-color: var(--color-bg-card);
  }
  .canal--highlight { border-color: var(--color-primary-light); background-color: var(--color-primary-subtle); }
  .canal__icon { flex-shrink: 0; width: 40px; height: 40px; display: flex; align-items: center; justify-content: center; }
  .canal__info h3 { font-family: var(--font-body); font-size: var(--text-base); font-weight: var(--font-semibold); margin-bottom: var(--space-1); display: flex; align-items: center; gap: var(--space-2); }
  .canal__info p { font-size: var(--text-sm); color: var(--color-text-secondary); line-height: var(--leading-relaxed); }
  .canal__badge {
    display: inline-block; font-size: var(--text-xs); font-weight: var(--font-semibold);
    letter-spacing: var(--tracking-wide); text-transform: uppercase;
    background-color: var(--color-primary); color: var(--color-text-inverse);
    padding: 2px 8px; border-radius: var(--radius-sm);
  }
  .canal__hours { font-size: var(--text-xs); color: var(--color-text-disabled); margin-top: var(--space-1); }
  .localizacao { margin-top: var(--space-6); padding: var(--space-5); background-color: var(--color-bg-card); border: 1px solid var(--color-border); border-radius: var(--radius-lg); }
  .localizacao__title { font-family: var(--font-body); font-size: var(--text-base); font-weight: var(--font-semibold); margin-bottom: var(--space-3); }
  .localizacao__address { font-size: var(--text-sm); color: var(--color-text-secondary); line-height: var(--leading-relaxed); margin-bottom: var(--space-2); }
  .localizacao__ref { font-size: var(--text-xs); color: var(--color-text-disabled); margin-bottom: var(--space-4); }
  .localizacao__hours p { font-size: var(--text-sm); color: var(--color-text-secondary); margin-bottom: var(--space-1); }
  .form-intro { font-size: var(--text-sm); color: var(--color-text-secondary); margin-bottom: var(--space-6); }
  .contact-form { display: flex; flex-direction: column; gap: var(--space-5); }
  .form-lgpd-note { font-size: var(--text-xs); color: var(--color-text-disabled); line-height: var(--leading-relaxed); margin-top: var(--space-2); }
  @media (max-width: 768px) {
    .contato-grid { grid-template-columns: 1fr; }
  }
</style>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement | null;
  const submitBtn = document.getElementById('submit-btn');
  const lgpdError = document.getElementById('lgpd-error');

  form?.addEventListener('submit', (e) => {
    e.preventDefault();
    const lgpd = form.querySelector<HTMLInputElement>('#lgpd');
    if (!lgpd?.checked) {
      if (lgpdError) lgpdError.style.display = 'block';
      lgpd?.focus();
      return;
    }
    if (lgpdError) lgpdError.style.display = 'none';
    if (submitBtn) {
      submitBtn.textContent = 'Enviando...';
      (submitBtn as HTMLButtonElement).disabled = true;
    }
    // Redireciona para /obrigado
    // TODO: Configurar endpoint real (Formspree, Netlify Forms, etc.) antes do lançamento.
    setTimeout(() => { window.location.href = '/obrigado'; }, 600);
  });
</script>
