---
/**
 * Página /blog — template criado como compensação ao WARN F do validation-report.
 * Nenhum artigo foi publicado ainda. Esta página serve como index do blog.
 */
import Base from '../../layouts/Base.astro';
import CTASection from '../../components/CTASection.astro';
import { clinic, whatsappLink } from '../../config/clinic';

const waUrl = whatsappLink();
const title = `Blog de Saúde — ${clinic.name} | ${clinic.city}`;
const description = `Conteúdo educativo sobre saúde, prevenção e bem-estar pela equipe da ${clinic.name}. Informação de qualidade para cuidar da sua saúde em ${clinic.city}.`;
---

<Base title={title} description={description}>
  <section class='blog-hero'>
    <div class='container blog-hero__inner'>
      <span class='blog-hero__eyebrow'>Blog</span>
      <h1 class='blog-hero__title'>Conteúdo sobre saúde e bem-estar</h1>
      <p class='blog-hero__lead'>
        Dicas, orientações e informações de qualidade para ajudar você a cuidar da sua saúde com mais conhecimento e tranquilidade. Produzido pela nossa equipe médica.
      </p>
    </div>
  </section>

  <section class='section' aria-labelledby='blog-content-title'>
    <div class='container'>
      <h2 class='sr-only' id='blog-content-title'>Artigos do blog</h2>
      <div class='blog-empty'>
        <div class='blog-empty__icon' aria-hidden='true'>
          <svg xmlns='http://www.w3.org/2000/svg' width='64' height='64' viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='1' stroke-linecap='round' stroke-linejoin='round'><path d='M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z'/><polyline points='14 2 14 8 20 8'/><line x1='16' y1='13' x2='8' y2='13'/><line x1='16' y1='17' x2='8' y2='17'/><polyline points='10 9 9 9 8 9'/></svg>
        </div>
        <h2 class='blog-empty__title'>Conteúdo em breve</h2>
        <p class='blog-empty__text'>
          Estamos preparando artigos educativos sobre saúde, prevenção e bem-estar para você. Em breve, nosso blog estará repleto de conteúdo de qualidade produzido pela nossa equipe médica.
        </p>
        <p class='blog-empty__text'>
          Enquanto isso, se tiver alguma dúvida sobre saúde ou quiser agendar uma consulta, nossa equipe está disponível pelo WhatsApp.
        </p>
        <a href={waUrl} class='btn btn-primary btn-lg' target='_blank' rel='noopener noreferrer' style='margin-top:var(--space-4)'>Falar com nossa equipe</a>
      </div>
    </div>
  </section>

  <CTASection
    title='Cuide da sua saúde com quem entende'
    text='Não espere ter dúvidas para falar com a gente. Nossa equipe está aqui para orientar você e agendar sua consulta de forma simples e rápida.'
    ctaPrimaryText='Agendar pelo WhatsApp'
    ctaPrimaryHref={waUrl}
    ctaSecondaryText='Ver especialidades'
    ctaSecondaryHref='/servicos'
    primaryIsWhatsApp={true}
  />
</Base>

<style>
  .blog-hero {
    background: linear-gradient(135deg, #2D6A4F 0%, #52B788 100%);
    padding: var(--space-20) 0;
    color: var(--color-text-inverse);
  }
  .blog-hero__inner { max-width: 640px; }
  .blog-hero__eyebrow {
    display: inline-block; font-size: var(--text-xs); font-weight: var(--font-semibold);
    letter-spacing: var(--tracking-wide); text-transform: uppercase;
    color: var(--color-accent-light); margin-bottom: var(--space-4);
  }
  .blog-hero__title { font-size: clamp(var(--text-4xl), 6vw, var(--text-5xl)); color: var(--color-text-inverse); margin-bottom: var(--space-4); }
  .blog-hero__lead { font-size: var(--text-lg); color: rgba(255,255,255,0.9); line-height: var(--leading-relaxed); max-width: 520px; }
  .blog-empty {
    max-width: 560px; margin: 0 auto;
    text-align: center; padding: var(--space-12) 0;
    display: flex; flex-direction: column; align-items: center; gap: var(--space-4);
  }
  .blog-empty__icon { color: var(--color-text-disabled); }
  .blog-empty__title { font-size: var(--text-3xl); color: var(--color-text-primary); }
  .blog-empty__text { font-size: var(--text-base); color: var(--color-text-secondary); line-height: var(--leading-relaxed); }
  .sr-only { position: absolute; width: 1px; height: 1px; padding: 0; margin: -1px; overflow: hidden; clip: rect(0,0,0,0); white-space: nowrap; border-width: 0; }
</style>
