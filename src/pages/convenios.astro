---
/**
 * Página /convenios — criada como compensação ao FAIL F do validation-report.
 * site-content.md não possui conteúdo dedicado para esta rota (apenas uma seção
 * na Home). Esta página foi gerada com base na seção "Convênios Aceitos" da Home.
 * Preencher com os convênios reais da clínica antes do lançamento.
 */
import Base from '../layouts/Base.astro';
import CTASection from '../components/CTASection.astro';
import { clinic, whatsappLink } from '../config/clinic';

const waUrl = whatsappLink('Olá, gostaria de verificar se meu convênio é aceito');
const title = `Convênios Aceitos — ${clinic.name} | ${clinic.city}`;
const description = `Confira os planos de saúde aceitos pela ${clinic.name} em ${clinic.city}. Consulte nossa equipe para verificar a cobertura da sua especialidade.`;
---

<Base title={title} description={description}>
  <section class='conv-hero'>
    <div class='container conv-hero__inner'>
      <span class='conv-hero__eyebrow'>Convênios</span>
      <h1 class='conv-hero__title'>Convênios aceitos</h1>
      <p class='conv-hero__lead'>
        Trabalhamos com os principais planos de saúde para facilitar o seu acesso ao cuidado. Consulte nossa equipe para verificar a cobertura da sua especialidade.
      </p>
      <a href={waUrl} class='btn btn-whatsapp btn-lg' target='_blank' rel='noopener noreferrer'>
        <svg xmlns='http://www.w3.org/2000/svg' width='20' height='20' viewBox='0 0 24 24' fill='currentColor' aria-hidden='true'><path d='M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z'/></svg>
        Verificar meu convênio pelo WhatsApp
      </a>
    </div>
  </section>

  <section class='section' aria-labelledby='conv-logos-title'>
    <div class='container'>
      <h2 id='conv-logos-title' class='section__title'>Planos aceitos</h2>
      <div class='conv-logos-area'>
        <p class='conv-logos-note'>ℹ️ <em>Os logos e nomes dos convênios serão exibidos aqui após confirmação com o cliente. Se a clínica não aceitar convênios, substituir esta seção por informações sobre formas de pagamento aceitas.</em></p>
      </div>
    </div>
  </section>

  <section class='section section--alt' aria-labelledby='part-title'>
    <div class='container part-section'>
      <div>
        <h2 id='part-title'>Atendimento particular</h2>
        <p class='part-text'>Além dos convênios, também realizamos atendimentos particulares. Os valores variam de acordo com a especialidade e o tipo de consulta.</p>
        <p class='part-text'>Para saber o preço específico da consulta que você precisa, fale com nossa equipe pelo WhatsApp — vamos orientar você com prazer.</p>
        <a href={waUrl} class='btn btn-primary' target='_blank' rel='noopener noreferrer' style='margin-top:var(--space-6)'>Consultar valores pelo WhatsApp</a>
      </div>
      <div class='part-info'>
        <h3>Dúvidas frequentes</h3>
        <details class='faq'>
          <summary class='faq__q'>Meu plano é aceito na clínica?</summary>
          <p class='faq__a'>Entre em contato pelo WhatsApp ou telefone para confirmar se o seu plano de saúde é aceito e quais especialidades são cobertas.</p>
        </details>
        <details class='faq'>
          <summary class='faq__q'>O plano cobre todas as especialidades?</summary>
          <p class='faq__a'>A cobertura varia de acordo com cada plano e especialidade. Nossa equipe pode orientar você antes do agendamento.</p>
        </details>
        <details class='faq'>
          <summary class='faq__q'>Como faço para agendar pelo convênio?</summary>
          <p class='faq__a'>Basta entrar em contato pelo WhatsApp informando o nome do seu plano. Nossa equipe orienta sobre os próximos passos.</p>
        </details>
      </div>
    </div>
  </section>

  <CTASection
    title='Ficou com dúvidas sobre convênios?'
    text='Nossa equipe responde em até 15 minutos durante o horário comercial. Fale com a gente pelo WhatsApp.'
    ctaPrimaryText='Falar pelo WhatsApp'
    ctaPrimaryHref={waUrl}
    ctaSecondaryText='Ir para contato'
    ctaSecondaryHref='/contato'
    primaryIsWhatsApp={true}
  />
</Base>

<style>
  .conv-hero {
    background: linear-gradient(135deg, #2D6A4F 0%, #52B788 100%);
    padding: var(--space-20) 0;
    color: var(--color-text-inverse);
  }
  .conv-hero__inner { max-width: 640px; }
  .conv-hero__eyebrow {
    display: inline-block; font-size: var(--text-xs); font-weight: var(--font-semibold);
    letter-spacing: var(--tracking-wide); text-transform: uppercase;
    color: var(--color-accent-light); margin-bottom: var(--space-4);
  }
  .conv-hero__title { font-size: clamp(var(--text-4xl), 6vw, var(--text-5xl)); color: var(--color-text-inverse); margin-bottom: var(--space-4); }
  .conv-hero__lead { font-size: var(--text-lg); color: rgba(255,255,255,0.9); line-height: var(--leading-relaxed); margin-bottom: var(--space-8); max-width: 520px; }
  .conv-logos-area {
    min-height: 200px; border: 2px dashed var(--color-border);
    border-radius: var(--radius-xl); padding: var(--space-12);
    display: flex; align-items: center; justify-content: center;
    background-color: var(--color-bg-section-alt);
  }
  .conv-logos-note { font-size: var(--text-sm); color: var(--color-text-disabled); text-align: center; font-style: italic; }
  .part-section { display: grid; grid-template-columns: 1fr 1fr; gap: var(--space-12); align-items: start; }
  .part-text { font-size: var(--text-base); color: var(--color-text-secondary); line-height: var(--leading-relaxed); margin-bottom: var(--space-3); }
  .part-info h3 { font-size: var(--text-2xl); margin-bottom: var(--space-6); }
  .faq { border: 1px solid var(--color-border); border-radius: var(--radius-md); margin-bottom: var(--space-3); overflow: hidden; }
  .faq__q {
    display: flex; align-items: center; justify-content: space-between;
    padding: var(--space-4) var(--space-5); font-size: var(--text-base); font-weight: var(--font-semibold);
    cursor: pointer; list-style: none; background-color: var(--color-bg-card);
    transition: background-color var(--duration-fast) var(--ease-out);
  }
  .faq__q:hover { background-color: var(--color-primary-subtle); color: var(--color-primary); }
  .faq__a { padding: var(--space-4) var(--space-5); font-size: var(--text-base); color: var(--color-text-secondary); line-height: var(--leading-relaxed); background-color: var(--color-bg-page); }
  @media (max-width: 768px) {
    .part-section { grid-template-columns: 1fr; }
  }
</style>
