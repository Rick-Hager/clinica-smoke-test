---
import Base from '../layouts/Base.astro';
import ServiceCard from '../components/ServiceCard.astro';
import TestimonialCard from '../components/TestimonialCard.astro';
import CTASection from '../components/CTASection.astro';
import { clinic, whatsappLink, specialties } from '../config/clinic';

const waUrl = whatsappLink();
const waConvenio = whatsappLink('Olá, gostaria de verificar se meu convênio é aceito');
const title = `${clinic.name} — Atendimento Médico Humanizado | ${clinic.city}`;
const description = `Consultas médicas com acolhimento e excelência técnica em ${clinic.city}. Agende pelo WhatsApp ou online, sem filas. Especialidades: clínica geral, cardiologia, dermatologia, ginecologia e ortopedia.`;

const diferenciais = [
  { emoji: '🌿', title: 'Agendamento sem complicação', text: 'Pelo WhatsApp, pelo site ou por telefone — você escolhe. Respondemos em até 15 minutos durante o horário comercial. Sem filas, sem burocracia.' },
  { emoji: '🩺', title: 'Médicos que ouvem você de verdade', text: 'Consultas com tempo adequado e profissionais que conhecem o seu histórico. Aqui, o cuidado começa antes de você entrar na sala.' },
  { emoji: '📋', title: 'Transparência de ponta a ponta', text: 'Preços claros, orientações por escrito após a consulta e acompanhamento real do seu tratamento. Sem surpresas.' },
  { emoji: '💚', title: 'Ambiente pensado para você', text: 'Espaço físico acolhedor, equipe receptiva e uma experiência que reduz a ansiedade — porque sabemos que ir ao médico nem sempre é fácil.' },
];

const steps = [
  { num: '01', title: 'Escolha sua especialidade', text: 'Encontre o cuidado que você precisa entre nossas especialidades.' },
  { num: '02', title: 'Agende pelo WhatsApp ou online', text: 'Em poucos minutos, sem filas e sem complicação.' },
  { num: '03', title: 'Seja atendido com atenção', text: 'Consulta com tempo adequado, médico que escuta e orientações claras.' },
  { num: '04', title: 'Acompanhamento pós-consulta', text: 'Receba orientações por escrito e saiba que estamos aqui se surgir qualquer dúvida.' },
];

const testimonials = [
  { quote: 'Fui atendida com muito cuidado e atenção. O médico escutou tudo que eu tinha para contar, sem pressa. Me senti acolhida desde o momento em que entrei na recepção.', author: 'M.S., paciente há 2 anos' },
  { quote: 'Consegui agendar pelo WhatsApp em menos de 5 minutos. Fui atendido no horário marcado e saí com todas as minhas dúvidas respondidas. Recomendo muito.', author: 'R.A., paciente' },
  { quote: 'Depois de anos buscando uma clínica onde me sentisse bem, finalmente encontrei. A equipe é atenciosa, o ambiente é agradável e o atendimento é muito humano.', author: 'C.L., paciente há 1 ano' },
];

const schema = {
  '@context': 'https://schema.org',
  '@type': 'MedicalClinic',
  name: clinic.name,
  description,
  url: Astro.site?.toString() ?? '/',
  telephone: clinic.phone,
  email: clinic.email,
  address: {
    '@type': 'PostalAddress',
    addressLocality: clinic.city,
    addressCountry: 'BR',
  },
  openingHoursSpecification: [
    { '@type': 'OpeningHoursSpecification', dayOfWeek: ['Monday','Tuesday','Wednesday','Thursday','Friday'], opens: '08:00', closes: '18:00' },
    { '@type': 'OpeningHoursSpecification', dayOfWeek: ['Saturday'], opens: '08:00', closes: '12:00' },
  ],
};
---

<Base title={title} description={description}>
  <script type='application/ld+json' set:html={JSON.stringify(schema)} />

  <!-- HERO -->
  <section class='hero'>
    <div class='container hero__inner'>
      <span class='hero__eyebrow'>Cuidado com propósito</span>
      <h1 class='hero__title'>Saúde que começa<br />com escuta</h1>
      <p class='hero__lead'>
        Na Clínica Smoke Test, você não é um número de prontuário. Nossa equipe combina qualificação técnica e atenção genuína para oferecer o cuidado que você merece — do primeiro contato ao acompanhamento pós-consulta.
      </p>
      <div class='hero__actions'>
        <a href={waUrl} class='btn btn-whatsapp btn-lg' target='_blank' rel='noopener noreferrer'>
          <svg xmlns='http://www.w3.org/2000/svg' width='20' height='20' viewBox='0 0 24 24' fill='currentColor' aria-hidden='true'><path d='M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z'/></svg>
          Agendar pelo WhatsApp
        </a>
        <a href='/servicos' class='btn btn-inverse btn-lg'>Conheça nossas especialidades</a>
      </div>
    </div>
  </section>

  <!-- DIFERENCIAIS -->
  <section class='section' aria-labelledby='dif-title'>
    <div class='container'>
      <span class='section__eyebrow'>Por que nos escolher</span>
      <h2 class='section__title' id='dif-title'>Por que pacientes escolhem a Clínica Smoke Test</h2>
      <div class='dif-grid'>
        {diferenciais.map((d) => (
          <article class='dif-card'>
            <span class='dif-card__emoji' aria-hidden='true'>{d.emoji}</span>
            <h3 class='dif-card__title'>{d.title}</h3>
            <p class='dif-card__text'>{d.text}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- ESPECIALIDADES -->
  <section class='section section--alt' aria-labelledby='esp-title'>
    <div class='container'>
      <span class='section__eyebrow'>Especialidades</span>
      <h2 class='section__title' id='esp-title'>Nossas especialidades</h2>
      <p class='section__lead'>Cuidado completo para você e sua família em um só lugar.</p>
      <div class='grid-services'>
        {specialties.map((s) => (
          <ServiceCard slug={s.slug} name={s.name} short={s.short} icon={s.icon} />
        ))}
      </div>
      <div style='margin-top:var(--space-8);text-align:center'>
        <a href='/servicos' class='btn btn-secondary'>Ver todas as especialidades</a>
      </div>
    </div>
  </section>

  <!-- COMO FUNCIONA -->
  <section class='section' aria-labelledby='steps-title'>
    <div class='container'>
      <span class='section__eyebrow'>Como funciona</span>
      <h2 class='section__title' id='steps-title'>Agendar é simples. Cuidar é o que fazemos.</h2>
      <div class='steps-grid'>
        {steps.map((s) => (
          <article class='step'>
            <span class='step__num' aria-hidden='true'>{s.num}</span>
            <h3 class='step__title'>{s.title}</h3>
            <p class='step__text'>{s.text}</p>
          </article>
        ))}
      </div>
      <div style='margin-top:var(--space-10);text-align:center'>
        <a href={waUrl} class='btn btn-primary btn-lg' target='_blank' rel='noopener noreferrer'>Agendar agora</a>
      </div>
    </div>
  </section>

  <!-- DEPOIMENTOS -->
  <section class='section section--alt' aria-labelledby='dep-title'>
    <div class='container'>
      <span class='section__eyebrow'>Depoimentos</span>
      <h2 class='section__title' id='dep-title'>O que nossos pacientes dizem</h2>
      <div class='testimonials-grid'>
        {testimonials.map((t) => (
          <TestimonialCard quote={t.quote} author={t.author} />
        ))}
      </div>
      <p class='dep-note'>Depoimentos genéricos de satisfação com o atendimento — sem menção a diagnóstico ou resultado de tratamento (conformidade CFM). Substituir por depoimentos reais com autorização expressa antes do lançamento.</p>
    </div>
  </section>

  <!-- CONVÊNIOS -->
  <section class='section' aria-labelledby='conv-title'>
    <div class='container conv-section'>
      <div class='conv-content'>
        <span class='section__eyebrow'>Convênios</span>
        <h2 class='section__title' id='conv-title'>Convênios aceitos</h2>
        <p class='conv-text'>Trabalhamos com os principais planos de saúde para facilitar o seu acesso ao cuidado. Consulte nossa equipe para verificar a cobertura da sua especialidade.</p>
        <div class='conv-actions'>
          <a href={waConvenio} class='btn btn-whatsapp' target='_blank' rel='noopener noreferrer'>
            <svg xmlns='http://www.w3.org/2000/svg' width='16' height='16' viewBox='0 0 24 24' fill='currentColor' aria-hidden='true'><path d='M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z'/></svg>
            Verificar meu convênio
          </a>
          <a href='/convenios' class='btn btn-secondary'>Ver convênios</a>
        </div>
      </div>
      <div class='conv-placeholder' aria-label='Espaço para logos de convênios'>
        <p>Logos dos convênios serão exibidos aqui após confirmação com o cliente.</p>
      </div>
    </div>
  </section>

  <!-- CTA FINAL -->
  <CTASection
    title='Pronto para cuidar da sua saúde?'
    text='Nossa equipe está aqui para receber você com atenção e cuidado. Agende sua consulta — é simples, rápido e sem complicação.'
    ctaPrimaryText='Agendar pelo WhatsApp'
    ctaPrimaryHref={waUrl}
    ctaSecondaryText='Ver todas as especialidades'
    ctaSecondaryHref='/servicos'
    primaryIsWhatsApp={true}
  />
</Base>

<style>
  /* HERO */
  .hero {
    background: linear-gradient(135deg, #2D6A4F 0%, #52B788 100%);
    padding: var(--space-24) 0;
    color: var(--color-text-inverse);
    min-height: 540px;
    display: flex; align-items: center;
  }
  .hero__inner { max-width: 680px; }
  .hero__eyebrow {
    display: inline-block; font-size: var(--text-xs); font-weight: var(--font-semibold);
    letter-spacing: var(--tracking-wide); text-transform: uppercase;
    color: var(--color-accent-light); margin-bottom: var(--space-4);
  }
  .hero__title {
    font-size: clamp(var(--text-4xl), 7vw, var(--text-6xl));
    color: var(--color-text-inverse);
    margin-bottom: var(--space-6);
    line-height: var(--leading-tight); letter-spacing: var(--tracking-tight);
  }
  .hero__lead {
    font-size: clamp(var(--text-base), 2.5vw, var(--text-lg));
    color: rgba(255,255,255,0.9); line-height: var(--leading-relaxed);
    margin-bottom: var(--space-8); max-width: 560px;
  }
  .hero__actions { display: flex; flex-wrap: wrap; gap: var(--space-4); align-items: center; }
  /* DIFERENCIAIS */
  .dif-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: var(--space-6); margin-top: var(--space-8); }
  .dif-card {
    background-color: var(--color-bg-card);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    padding: var(--space-6);
    box-shadow: var(--shadow-sm);
    transition: box-shadow var(--duration-normal) var(--ease-out), transform var(--duration-normal) var(--ease-out);
  }
  .dif-card:hover { box-shadow: var(--shadow-md); transform: translateY(-2px); }
  .dif-card__emoji { font-size: 2rem; display: block; margin-bottom: var(--space-3); }
  .dif-card__title { font-family: var(--font-body); font-size: var(--text-base); font-weight: var(--font-semibold); margin-bottom: var(--space-2); }
  .dif-card__text { font-size: var(--text-sm); color: var(--color-text-secondary); line-height: var(--leading-relaxed); }
  /* STEPS */
  .steps-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: var(--space-6); margin-top: var(--space-8); }
  .step { display: flex; flex-direction: column; gap: var(--space-3); }
  .step__num {
    font-family: var(--font-heading); font-size: var(--text-4xl); font-weight: var(--font-bold);
    color: var(--color-primary-subtle); line-height: 1;
  }
  .step__title { font-family: var(--font-body); font-size: var(--text-base); font-weight: var(--font-semibold); }
  .step__text { font-size: var(--text-sm); color: var(--color-text-secondary); line-height: var(--leading-relaxed); }
  /* DEPOIMENTOS */
  .testimonials-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: var(--space-6); margin-top: var(--space-8); }
  .dep-note { margin-top: var(--space-6); font-size: var(--text-xs); color: var(--color-text-disabled); font-style: italic; }
  /* CONVÊNIOS */
  .conv-section { display: grid; grid-template-columns: 1fr 1fr; gap: var(--space-12); align-items: center; }
  .conv-text { font-size: var(--text-base); color: var(--color-text-secondary); line-height: var(--leading-relaxed); margin-bottom: var(--space-6); }
  .conv-actions { display: flex; flex-wrap: wrap; gap: var(--space-3); }
  .conv-placeholder {
    background-color: var(--color-bg-section-alt); border: 2px dashed var(--color-border);
    border-radius: var(--radius-xl); padding: var(--space-12);
    display: flex; align-items: center; justify-content: center; min-height: 180px;
  }
  .conv-placeholder p { font-size: var(--text-sm); color: var(--color-text-disabled); text-align: center; font-style: italic; }
  /* RESPONSIVE */
  @media (max-width: 1024px) {
    .dif-grid { grid-template-columns: repeat(2, 1fr); }
    .steps-grid { grid-template-columns: repeat(2, 1fr); }
    .testimonials-grid { grid-template-columns: 1fr 1fr; }
    .conv-section { grid-template-columns: 1fr; }
  }
  @media (max-width: 640px) {
    .hero { padding: var(--space-16) 0; min-height: auto; }
    .dif-grid { grid-template-columns: 1fr; }
    .steps-grid { grid-template-columns: 1fr; }
    .testimonials-grid { grid-template-columns: 1fr; }
    .hero__actions { flex-direction: column; align-items: flex-start; }
  }
</style>
