---
import Base from './Base.astro';
import CTASection from '../components/CTASection.astro';
import { clinic, whatsappLink } from '../config/clinic';

interface Props {
  title: string;
  description: string;
  specialtyName: string;
  slug: string;
  lead: string;
  whatWeDo: string[];
  whenToConsult: string[];
  ctaMessage?: string;
  note?: string;
}

const { title, description, specialtyName, slug, lead, whatWeDo, whenToConsult, ctaMessage, note } = Astro.props;
const waUrl = whatsappLink(ctaMessage ?? `Olá, gostaria de agendar uma consulta de ${specialtyName.toLowerCase()}`);
const origin = Astro.site?.toString().replace(/\/$/, '') ?? '';

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Início', item: `${origin}/` },
    { '@type': 'ListItem', position: 2, name: 'Especialidades', item: `${origin}/servicos` },
    { '@type': 'ListItem', position: 3, name: specialtyName, item: `${origin}/servicos/${slug}` },
  ],
};
---

<Base title={title} description={description}>
  <script type='application/ld+json' set:html={JSON.stringify(breadcrumbSchema)} />

  <nav class='container breadcrumb' aria-label='Localização na página'>
    <a href='/'>Início</a>
    <span class='breadcrumb__sep' aria-hidden='true'>›</span>
    <a href='/servicos'>Especialidades</a>
    <span class='breadcrumb__sep' aria-hidden='true'>›</span>
    <span aria-current='page'>{specialtyName}</span>
  </nav>

  <section class='svc-hero'>
    <div class='container svc-hero__inner'>
      <span class='section__eyebrow' style='color:var(--color-accent-light)'>Especialidade</span>
      <h1 class='svc-hero__title'>{specialtyName}</h1>
      <p class='svc-hero__lead'>{lead}</p>
      <a href={waUrl} class='btn btn-whatsapp btn-lg' target='_blank' rel='noopener noreferrer'>
        <svg xmlns='http://www.w3.org/2000/svg' width='20' height='20' viewBox='0 0 24 24' fill='currentColor' aria-hidden='true'><path d='M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z'/></svg>
        Agendar consulta de {specialtyName}
      </a>
    </div>
  </section>

  <section class='section'>
    <div class='container svc-detail'>
      <div class='svc-col'>
        <h2 class='svc-col__title'>O que fazemos</h2>
        <ul class='svc-list' role='list'>
          {whatWeDo.map((item) => (
            <li class='svc-list__item'>
              <span class='svc-list__check' aria-hidden='true'>
                <svg xmlns='http://www.w3.org/2000/svg' width='16' height='16' viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2.5' stroke-linecap='round' stroke-linejoin='round'><path d='M20 6 9 17l-5-5'/></svg>
              </span>
              <span>{item}</span>
            </li>
          ))}
        </ul>
      </div>
      <div class='svc-col'>
        <h2 class='svc-col__title'>Quando consultar</h2>
        <ul class='svc-list' role='list'>
          {whenToConsult.map((item) => (
            <li class='svc-list__item'>
              <span class='svc-list__check' aria-hidden='true'>
                <svg xmlns='http://www.w3.org/2000/svg' width='16' height='16' viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2.5' stroke-linecap='round' stroke-linejoin='round'><path d='M20 6 9 17l-5-5'/></svg>
              </span>
              <span>{item}</span>
            </li>
          ))}
        </ul>
        {note && <div class='svc-note'><p>{note}</p></div>}
      </div>
    </div>
  </section>

  <CTASection
    title='Pronto para cuidar da sua saúde?'
    text={`Nossa equipe está aqui para receber você com atenção e cuidado. Agende sua consulta de ${specialtyName.toLowerCase()} — é simples, rápido e sem complicação.`}
    ctaPrimaryText={`Agendar consulta de ${specialtyName}`}
    ctaPrimaryHref={waUrl}
    ctaSecondaryText='Ver todas as especialidades'
    ctaSecondaryHref='/servicos'
    primaryIsWhatsApp={true}
  />
</Base>

<style>
  .svc-hero {
    background: linear-gradient(135deg, #2D6A4F 0%, #52B788 100%);
    padding: var(--space-16) 0 var(--space-20);
    color: var(--color-text-inverse);
  }
  .svc-hero__inner { max-width: 720px; }
  .svc-hero__title {
    font-size: clamp(var(--text-4xl), 6vw, var(--text-5xl));
    color: var(--color-text-inverse);
    margin-bottom: var(--space-4);
    line-height: var(--leading-tight);
  }
  .svc-hero__lead {
    font-size: var(--text-lg);
    color: rgba(255,255,255,0.9);
    line-height: var(--leading-relaxed);
    margin-bottom: var(--space-8);
    max-width: 560px;
  }
  .svc-detail {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-12);
  }
  .svc-col__title {
    font-size: var(--text-2xl);
    margin-bottom: var(--space-6);
  }
  .svc-list {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }
  .svc-list__item {
    display: flex;
    align-items: flex-start;
    gap: var(--space-3);
    font-size: var(--text-base);
    color: var(--color-text-secondary);
    line-height: var(--leading-relaxed);
  }
  .svc-list__check {
    flex-shrink: 0;
    width: 24px;
    height: 24px;
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: var(--color-primary-subtle);
    color: var(--color-primary);
    border-radius: var(--radius-full);
    margin-top: 1px;
  }
  .svc-note {
    margin-top: var(--space-6);
    padding: var(--space-4);
    background-color: var(--color-bg-section-alt);
    border-left: 3px solid var(--color-primary);
    border-radius: 0 var(--radius-md) var(--radius-md) 0;
    font-size: var(--text-sm);
    color: var(--color-text-secondary);
    line-height: var(--leading-relaxed);
  }
  @media (max-width: 768px) {
    .svc-detail { grid-template-columns: 1fr; gap: var(--space-8); }
  }
</style>
