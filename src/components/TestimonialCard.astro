---
interface Props {
  quote: string;
  author: string;
  rating?: number;
}
const { quote, author, rating = 5 } = Astro.props;
const stars = Array.from({ length: rating }, () => '★').join('');
---

<article class='tcard'>
  <p class='tcard__stars' aria-label={`${rating} de 5 estrelas`} role='img'>{stars}</p>
  <blockquote class='tcard__quote'>
    <p>&#8220;{quote}&#8221;</p>
  </blockquote>
  <footer class='tcard__author'><cite>{author}</cite></footer>
</article>

<style>
  .tcard {
    padding: var(--space-8);
    background-color: var(--color-bg-card);
    border-left: 4px solid var(--color-primary);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-sm);
    display: flex; flex-direction: column; gap: var(--space-4);
  }
  .tcard__stars { color: var(--color-accent); font-size: var(--text-base); letter-spacing: 0.05em; }
  .tcard__quote p {
    font-size: var(--text-base); font-style: italic;
    color: var(--color-text-primary); line-height: var(--leading-relaxed);
  }
  .tcard__author { font-size: var(--text-sm); font-weight: var(--font-medium); color: var(--color-text-secondary); }
</style>
