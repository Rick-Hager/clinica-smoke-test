---
// CookieBanner — LGPD (Lei 13.709/2018)
---
<div class='cookie-banner' id='cookie-banner' role='region' aria-label='Aviso de cookies' aria-live='polite'>
  <p class='cookie-banner__text'>
    Usamos cookies para melhorar sua experiência. Ao continuar navegando, você concorda com nossa
    <a href='/politica-de-privacidade' class='cookie-banner__link'>Política de Privacidade</a>.
  </p>
  <div class='cookie-banner__actions'>
    <button class='btn btn-sm btn-inverse' id='cookie-reject'>Recusar</button>
    <button class='btn btn-sm btn-primary' id='cookie-accept'>Aceitar</button>
  </div>
</div>

<style>
  .cookie-banner {
    position: fixed; bottom: 0; left: 0; right: 0; z-index: 9998;
    display: flex; align-items: center; justify-content: space-between; gap: var(--space-4);
    padding: var(--space-4) var(--space-6);
    background-color: var(--color-text-primary); color: var(--color-text-inverse);
    box-shadow: 0 -4px 24px rgba(0,0,0,0.15); flex-wrap: wrap;
    transform: translateY(100%);
    transition: transform var(--duration-slow) var(--ease-out);
  }
  .cookie-banner.is-visible { transform: translateY(0); }
  .cookie-banner__text { font-size: var(--text-sm); line-height: var(--leading-relaxed); flex: 1; min-width: 200px; }
  .cookie-banner__link { color: var(--color-primary-light); text-decoration: underline; }
  .cookie-banner__actions { display: flex; gap: var(--space-2); flex-shrink: 0; }
  .cookie-banner .btn-inverse { border-color: rgba(255,255,255,0.35); color: rgba(255,255,255,0.8); }
  .cookie-banner .btn-inverse:hover { background-color: rgba(255,255,255,0.12); color: var(--color-text-inverse); border-color: rgba(255,255,255,0.6); }
</style>

<script>
  const CONSENT_KEY = 'cst_cookie_consent';
  const banner = document.getElementById('cookie-banner');
  if (banner && !localStorage.getItem(CONSENT_KEY)) {
    setTimeout(() => banner.classList.add('is-visible'), 800);
  }
  document.getElementById('cookie-accept')?.addEventListener('click', () => {
    localStorage.setItem(CONSENT_KEY, 'accepted');
    document.getElementById('cookie-banner')?.classList.remove('is-visible');
  });
  document.getElementById('cookie-reject')?.addEventListener('click', () => {
    localStorage.setItem(CONSENT_KEY, 'rejected');
    document.getElementById('cookie-banner')?.classList.remove('is-visible');
  });
</script>
