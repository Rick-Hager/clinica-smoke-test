---
import { clinic, whatsappLink, specialties } from '../config/clinic';
const waUrl = whatsappLink();
const year = new Date().getFullYear();
---

<footer class='footer'>
  <div class='container footer__inner'>
    <div class='footer__brand'>
      <a href='/' class='footer__logo' aria-label={`${clinic.name} — página inicial`}>
        <svg xmlns='http://www.w3.org/2000/svg' width='26' height='26' viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='1.5' stroke-linecap='round' stroke-linejoin='round' aria-hidden='true'>
          <path d='M11 20A7 7 0 0 1 9.8 6.1C15.5 5 17 4.48 19 2c1 2 2 4.18 2 8 0 5.5-4.78 10-10 10Z'/>
          <path d='M2 21c0-3 1.85-5.36 5.08-6C9.5 14.52 12 13 13 12'/>
        </svg>
        <span class='footer__logo-text'>
          <span class='footer__logo-clinic'>Clínica</span>
          <span class='footer__logo-name'>Smoke Test</span>
        </span>
      </a>
      <p class='footer__tagline'>{clinic.tagline}</p>
      <a href={waUrl} class='btn btn-whatsapp btn-sm footer__wa' target='_blank' rel='noopener noreferrer'>
        <svg xmlns='http://www.w3.org/2000/svg' width='16' height='16' viewBox='0 0 24 24' fill='currentColor' aria-hidden='true'><path d='M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z'/></svg>
        Agendar agora
      </a>
    </div>

    <div class='footer__cols'>
      <div class='footer__col'>
        <h3 class='footer__col-title'>Especialidades</h3>
        <ul class='footer__links' role='list'>
          {specialties.map((s) => (
            <li><a href={`/servicos/${s.slug}`} class='footer__link'>{s.name}</a></li>
          ))}
          <li><a href='/servicos' class='footer__link'>Ver todas</a></li>
        </ul>
      </div>
      <div class='footer__col'>
        <h3 class='footer__col-title'>Clínica</h3>
        <ul class='footer__links' role='list'>
          <li><a href='/sobre' class='footer__link'>Sobre nós</a></li>
          <li><a href='/convenios' class='footer__link'>Convênios</a></li>
          <li><a href='/blog' class='footer__link'>Blog</a></li>
          <li><a href='/politica-de-privacidade' class='footer__link'>Política de Privacidade</a></li>
        </ul>
      </div>
      <div class='footer__col'>
        <h3 class='footer__col-title'>Contato</h3>
        <ul class='footer__links footer__links--contact' role='list'>
          <li>
            <svg xmlns='http://www.w3.org/2000/svg' width='14' height='14' viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2' stroke-linecap='round' stroke-linejoin='round' aria-hidden='true'><path d='M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 13a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.6 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z'/></svg>
            <span>{clinic.phone}</span>
          </li>
          <li>
            <svg xmlns='http://www.w3.org/2000/svg' width='14' height='14' viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2' stroke-linecap='round' stroke-linejoin='round' aria-hidden='true'><rect width='20' height='16' x='2' y='4' rx='2'/><path d='m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7'/></svg>
            <a href={`mailto:${clinic.email}`} class='footer__link'>{clinic.email}</a>
          </li>
          <li>
            <svg xmlns='http://www.w3.org/2000/svg' width='14' height='14' viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2' stroke-linecap='round' stroke-linejoin='round' aria-hidden='true'><path d='M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z'/><circle cx='12' cy='10' r='3'/></svg>
            <span>{clinic.address.street}<br />{clinic.address.cityState}</span>
          </li>
          <li>
            <svg xmlns='http://www.w3.org/2000/svg' width='14' height='14' viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2' stroke-linecap='round' stroke-linejoin='round' aria-hidden='true'><circle cx='12' cy='12' r='10'/><polyline points='12 6 12 12 16 14'/></svg>
            <span>{clinic.hours.weekdays}<br />{clinic.hours.saturday}</span>
          </li>
        </ul>
      </div>
    </div>
  </div>

  <div class='footer__bottom'>
    <div class='container footer__bottom-inner'>
      <p class='footer__copy'>&copy; {year} {clinic.name}. Todos os direitos reservados.</p>
      <p class='footer__rt'>Responsável técnico: {clinic.responsible.name}, {clinic.responsible.crm}</p>
      <a href='/politica-de-privacidade' class='footer__legal'>Política de Privacidade</a>
    </div>
  </div>
</footer>

<style>
  .footer { background-color: var(--color-bg-dark); color: var(--color-text-inverse); }
  .footer__inner {
    display: grid; grid-template-columns: 260px 1fr;
    gap: var(--space-16); padding: var(--space-16) 0 var(--space-12);
  }
  .footer__brand { display: flex; flex-direction: column; gap: var(--space-4); }
  .footer__logo { display: flex; align-items: center; gap: var(--space-2); text-decoration: none; color: var(--color-text-inverse); }
  .footer__logo:hover { text-decoration: none; opacity: 0.9; }
  .footer__logo-text { display: flex; flex-direction: column; line-height: 1.15; }
  .footer__logo-clinic { font-family: var(--font-heading); font-size: var(--text-xs); font-weight: var(--font-medium); color: rgba(255,255,255,0.65); }
  .footer__logo-name { font-family: var(--font-body); font-size: var(--text-sm); font-weight: var(--font-bold); color: var(--color-text-inverse); }
  .footer__tagline { font-size: var(--text-sm); color: rgba(255,255,255,0.65); font-style: italic; }
  .footer__wa { align-self: flex-start; }
  .footer__cols { display: grid; grid-template-columns: repeat(3, 1fr); gap: var(--space-8); }
  .footer__col-title {
    font-size: var(--text-xs); font-weight: var(--font-semibold);
    letter-spacing: var(--tracking-wide); text-transform: uppercase;
    color: rgba(255,255,255,0.5); margin-bottom: var(--space-4);
  }
  .footer__links { display: flex; flex-direction: column; gap: var(--space-3); }
  .footer__link { font-size: var(--text-sm); color: rgba(255,255,255,0.72); text-decoration: none; transition: color var(--duration-fast) var(--ease-out); }
  .footer__link:hover { color: var(--color-text-inverse); text-decoration: underline; }
  .footer__links--contact li { display: flex; align-items: flex-start; gap: var(--space-2); font-size: var(--text-sm); color: rgba(255,255,255,0.72); line-height: var(--leading-relaxed); }
  .footer__links--contact svg { flex-shrink: 0; margin-top: 3px; opacity: 0.65; }
  .footer__bottom { border-top: 1px solid rgba(255,255,255,0.12); padding: var(--space-5) 0; }
  .footer__bottom-inner { display: flex; align-items: center; justify-content: space-between; gap: var(--space-4); flex-wrap: wrap; }
  .footer__copy, .footer__rt { font-size: var(--text-xs); color: rgba(255,255,255,0.5); }
  .footer__legal { font-size: var(--text-xs); color: rgba(255,255,255,0.5); text-decoration: none; transition: color var(--duration-fast) var(--ease-out); }
  .footer__legal:hover { color: var(--color-text-inverse); text-decoration: underline; }
  @media (max-width: 1024px) {
    .footer__inner { grid-template-columns: 1fr; gap: var(--space-10); }
  }
  @media (max-width: 640px) {
    .footer__cols { grid-template-columns: 1fr 1fr; }
    .footer__cols .footer__col:last-child { grid-column: 1 / -1; }
    .footer__bottom-inner { flex-direction: column; align-items: flex-start; }
  }
  @media (max-width: 480px) {
    .footer__cols { grid-template-columns: 1fr; }
  }
</style>
